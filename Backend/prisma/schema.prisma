// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS MODEL
// ============================================
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  businesses  Business[]
  clients     Client[]
  invoices    Invoice[]
  accounts    Account[]

  @@map("users")
}

// ============================================
// BUSINESS MODEL
// ============================================
model Business {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  businessName String? @map("business_name")
  isIndividual Boolean @default(false) @map("is_individual")
  vanityUrl   String? @unique @map("vanity_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@map("business")
}

// ============================================
// CLIENT MODEL
// ============================================
model Client {
  id              Int     @id @default(autoincrement())
  userId          Int     @map("user_id")
  clientType      String  @map("client_type") // 'individual' or 'organization'
  organizationName String? @map("organization_name")
  firstName       String? @map("first_name")
  lastName        String? @map("last_name")
  email           String  @unique
  phoneNumber     String? @map("phone_number")
  faxNumber       String? @map("fax_number")
  websiteUrl      String? @map("website_url")
  currency        String?
  languageSelect  String? @map("language_select")
  address1        String?
  address2        String?
  city            String?
  stateName       String? @map("state_name")
  postalCode      String? @map("postal_code")
  country         String?
  taxId           String? @map("tax_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@map("clients")
}

// ============================================
// ACCOUNT MODEL
// ============================================
model Account {
  id            Int     @id @default(autoincrement())
  userId        Int     @map("user_id")
  accountName   String? @map("account_name")
  accountEmail  String? @map("account_email")
  accountPhone  String? @map("account_phone")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

// ============================================
// INVOICE MODEL
// ============================================
model Invoice {
  id              Int     @id @default(autoincrement())
  userId          Int     @map("user_id")
  businessId      Int?    @map("business_id")
  clientId        Int     @map("client_id")

  // Invoice Details
  invoiceNumber   String  @unique @map("invoice_number")
  invoiceDate     DateTime @map("invoice_date")
  dueDate         DateTime @map("due_date")

  // Invoice Metadata
  title           String  @default("Invoice")
  description     String?
  notes           String?
  language        String  @default("English (US)")
  currency        String
  purchaseOrder   String? @map("purchase_order")

  // Logo Storage
  logoUrl         String? @map("logo_url") // Path or cloud URL to logo file
  logoMimeType    String? @map("logo_mime_type") // e.g., 'image/png', 'image/jpeg'

  // Amounts
  subtotal        Decimal @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount  Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount     Decimal @default(0) @map("total_amount") @db.Decimal(12, 2)

  // Status
  status          String  @default("draft") // 'draft', 'sent', 'paid', 'overdue'
  paymentStatus   String  @default("unpaid") @map("payment_status") // 'unpaid', 'partial', 'paid'

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  sentAt          DateTime? @map("sent_at")
  paidAt          DateTime? @map("paid_at")

  // Relations
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  business        Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client          Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  taxes           InvoiceTax[]
  discounts       InvoiceDiscount[]
  payments        InvoicePayment[]

  @@index([userId])
  @@index([clientId])
  @@index([businessId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([invoiceDate])
  @@map("invoices")
}

// ============================================
// INVOICE ITEM MODEL
// ============================================
model InvoiceItem {
  id            Int     @id @default(autoincrement())
  invoiceId     Int     @map("invoice_id")

  // Item Details
  description   String
  quantity      Decimal @db.Decimal(10, 2)
  rate          Decimal @db.Decimal(12, 2)
  amount        Decimal @db.Decimal(12, 2)

  // Order
  itemOrder     Int?    @map("item_order")

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ============================================
// INVOICE TAX MODEL
// ============================================
model InvoiceTax {
  id            Int     @id @default(autoincrement())
  invoiceId     Int     @map("invoice_id")

  // Tax Details
  taxName       String  @map("tax_name")
  taxAmount     Decimal @map("tax_amount") @db.Decimal(12, 2)

  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_taxes")
}

// ============================================
// INVOICE DISCOUNT MODEL
// ============================================
model InvoiceDiscount {
  id              Int     @id @default(autoincrement())
  invoiceId       Int     @map("invoice_id")

  // Discount Details
  discountName    String  @map("discount_name")
  discountAmount  Decimal @map("discount_amount") @db.Decimal(12, 2)

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_discounts")
}

// ============================================
// INVOICE PAYMENT MODEL
// ============================================
model InvoicePayment {
  id              Int     @id @default(autoincrement())
  invoiceId       Int     @map("invoice_id")

  // Payment Details
  paymentAmount   Decimal @map("payment_amount") @db.Decimal(12, 2)
  paymentDate     DateTime @map("payment_date")
  paymentMethod   String? @map("payment_method") // 'cash', 'check', 'credit_card', 'bank_transfer', etc.
  transactionId   String? @map("transaction_id")
  notes           String?

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_payments")
}

